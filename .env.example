APP_NAME="OFX Tracker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------
# Banco de dados — MySQL (Sail)
# -----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=pagamento
DB_USERNAME=sail
DB_PASSWORD=password

# -----------------------------------------------------------------------
# Cache, Session e Queue — Redis (Sail)
# -----------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=redis

CACHE_STORE=redis

# -----------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------
# E-mail — Mailpit (UI em http://localhost:8025)
# -----------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ofxtracker.local"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------
# Sail — portas expostas no host
# -----------------------------------------------------------------------
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
EVOLUTION_PORT=8080

# -----------------------------------------------------------------------
# Evolution API (WhatsApp)
# -----------------------------------------------------------------------
EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_API_KEY=SUA_CHAVE_SECRETA_AQUI
EVOLUTION_INSTANCE=default

# Banco exclusivo da Evolution (container evolution-postgres)
EVOLUTION_DB_USER=postgres
EVOLUTION_DB_PASSWORD=postgres
EVOLUTION_DB_NAME=evolution

# -----------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------
# AWS (não utilizado por padrão)
# -----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
